# Google Analytics 4
# Get your Measurement ID from Google Analytics: https://analytics.google.com
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Search Console verification token
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Sentry monitoring
NEXT_PUBLIC_SENTRY_DSN=
# Optional server-specific DSN (fallbacks to NEXT_PUBLIC_SENTRY_DSN)
SENTRY_DSN=

# Contact form — Resend (required for /api/contact)
# Get a free API key at https://resend.com
RESEND_API_KEY=

# Email address that receives contact form submissions
CONTACT_TO_EMAIL=sinpetca68@gmail.com

# Sender address (must be a verified domain in Resend, or use onboarding@resend.dev for testing)
RESEND_FROM_EMAIL=contacto@sinpetca.com
